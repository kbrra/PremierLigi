@model PremierLigi.WebUI.Dtos.StadiumDtos.CreateStadiumDto
@{
    Layout = null;
}
<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
<div class="container">
    <br />
    <h3>Yeni Stadyum Ekle</h3>
    <br />
    <form method="post" action="/Stadium/CreateStadium">
        <div class="mb-3">
            <label>Stadyum Adı</label>
            <input type="text" name="StadiumName" class="form-control" placeholder="Örn: Old Trafford" />
        </div>
        <div class="mb-3">
            <label>Şehir</label>
            <input type="text" name="City" class="form-control" placeholder="Örn: Manchester" />
        </div>
        <div class="mb-3">
            <label>Kapasite</label>
            <input type="number" name="Capacity" class="form-control" placeholder="Örn: 74000" />
        </div>
        <button type="submit" class="btn btn-primary">Kaydet</button>
        <a href="/Stadium/StadiumList" class="btn btn-secondary">Geri Dön</a>
    </form>
</div>
