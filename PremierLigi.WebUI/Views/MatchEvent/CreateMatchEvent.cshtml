@model PremierLigi.WebUI.Dtos.MatchEventDtos.CreateMatchEventDto
@{
    Layout = null;
    int matchId = ViewBag.MatchId;
}
<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
<div class="container">
    <br />
    <h3>Maç Olayı Ekle</h3>
    <br />
    <form method="post" action="/MatchEvent/CreateMatchEvent">
        <input type="hidden" name="MatchId" value="@matchId" />
        <div class="mb-3">
            <label>Olay Tipi</label>
            <select name="ActionType" class="form-control">
                <option value="Goal">⚽ Gol</option>
                <option value="YellowCard">🟨 Sarı Kart</option>
                <option value="RedCard">🟥 Kırmızı Kart</option>
                <option value="Substitution">🔄 Değişiklik</option>
            </select>
        </div>
        <div class="mb-3">
            <label>Açıklama</label>
            <input type="text" name="Description" class="form-control" placeholder="Örn: Haaland gol attı" />
        </div>
        <div class="mb-3">
            <label>Dakika</label>
            <input type="number" name="Minute" class="form-control" min="1" max="120" />
        </div>
        <button type="submit" class="btn btn-primary">Kaydet</button>
        <a href="/MatchEvent/MatchEventList?matchId=@matchId" class="btn btn-secondary">Geri Dön</a>
    </form>
</div>
