@{
    ViewData["Title"] = "Takımlar";
}

<div class="pl-hero" style="padding:40px 0;">
    <div class="container">
        <h1 style="font-family:'Bebas Neue',sans-serif; font-size:2.5rem; color:white; letter-spacing:3px;">
            Tak<span style="color:#00ff85;">ımlar</span>
        </h1>
        <p style="color:rgba(255,255,255,0.5); font-size:0.9rem;">2025/26 Sezonu · 20 Takım</p>
    </div>
</div>

<div class="container mt-4">
    <div class="row g-3" id="teams-container">
        <div class="text-center py-5 text-muted col-12">Yükleniyor...</div>
    </div>
</div>

@section Scripts {
    <script>
        fetch('http://localhost:7146/api/Team')
            .then(r => r.json())
            .then(teams => {
                let html = '';
                teams.forEach(t => {
                    let logoHtml = t.logoUrl
                        ? `<img src="${t.logoUrl}" style="width:70px;height:70px;object-fit:contain;margin:0 auto 16px;display:block;" onerror="this.outerHTML='<div class=team-logo style=width:70px;height:70px;font-size:1.2rem;margin:0 auto 16px;>${t.teamName.split(' ').map(w=>w[0]).join('').substring(0,3).toUpperCase()}</div>'">`
                        : `<div class="team-logo" style="width:70px;height:70px;font-size:1.2rem;margin:0 auto 16px;">${t.teamName.split(' ').map(w=>w[0]).join('').substring(0,3).toUpperCase()}</div>`;

                    html += `<div class="col-md-4 col-lg-3">
                        <div class="pl-card text-center" style="cursor:pointer;transition:transform 0.2s;"
                             onmouseover="this.style.transform='translateY(-4px)'"
                             onmouseout="this.style.transform='translateY(0)'">
                            ${logoHtml}
                            <div style="font-weight:700;font-size:1rem;color:#38003c;">${t.teamName}</div>
                            <div style="color:#6b7280;font-size:0.8rem;margin-top:4px;">📍 ${t.city}</div>
                        </div>
                    </div>`;
                });
                document.getElementById('teams-container').innerHTML = html;
            });
    </script>
}
