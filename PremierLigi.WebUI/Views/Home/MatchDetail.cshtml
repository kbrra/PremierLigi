@{
    ViewData["Title"] = "Maç Detayı";
}

<div id="match-hero" class="pl-hero" style="padding:50px 0;">
    <div class="container">
        <div id="hero-content" class="text-center">
            <div class="text-white-50">Yükleniyor...</div>
        </div>
    </div>
</div>

<div class="container mt-4">
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="pl-section-title">Maç Olayları</div>
            <div class="pl-card" id="events-container">
                <div class="text-center text-muted py-3">Yükleniyor...</div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="pl-section-title">İstatistikler</div>
            <div class="pl-card" id="stats-container">
                <div class="text-center text-muted py-3">Yükleniyor...</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const matchId = @ViewBag.MatchId;
        let teamLogos = {};

        function teamLogoHtml(name, size) {
            const url = teamLogos[name];
            if (url) return `<img src="${url}" style="width:${size}px;height:${size}px;object-fit:contain;margin:0 auto 8px;display:block;" onerror="this.style.display='none'">`;
            return `<div class="team-logo" style="width:${size}px;height:${size}px;font-size:1rem;margin:0 auto 8px;">${(name||'').split(' ').map(w=>w[0]).join('').substring(0,3).toUpperCase()}</div>`;
        }

        // Önce logoları çek
        fetch('http://localhost:7146/api/Team')
            .then(r => r.json())
            .then(teams => {
                teams.forEach(t => { teamLogos[t.teamName] = t.logoUrl; });

                // Maç bilgisi
                fetch(`http://localhost:7146/api/Match/GetMatch?id=${matchId}`)
                    .then(r => r.json())
                    .then(m => {
                        let statusHtml = '';
                        if(m.status === 'Finished') {
                            statusHtml = `<div style="color:rgba(255,255,255,0.5);font-size:0.8rem;margin-bottom:8px;">MAÇ SONA ERDİ</div>`;
                        } else if(m.status === 'Ongoing') {
                            statusHtml = `<div style="margin-bottom:8px;"><span class="pl-status-live">CANLI</span></div>`;
                        } else {
                            let d = new Date(m.matchDate);
                            statusHtml = `<div style="color:rgba(255,255,255,0.5);font-size:0.8rem;margin-bottom:8px;">
                                ${d.toLocaleDateString('tr-TR',{day:'2-digit',month:'long',year:'numeric'})} ·
                                ${d.toLocaleTimeString('tr-TR',{hour:'2-digit',minute:'2-digit'})}
                            </div>`;
                        }
                        let scoreHtml = m.status === 'NotPlayed'
                            ? `<span style="font-size:3rem;letter-spacing:8px;color:rgba(255,255,255,0.3);">VS</span>`
                            : `<span style="font-family:'Bebas Neue',sans-serif;font-size:4rem;letter-spacing:8px;color:white;">${m.homeScore} - ${m.awayScore}</span>`;

                        document.getElementById('hero-content').innerHTML = `
                            ${statusHtml}
                            <div style="display:flex;align-items:center;justify-content:center;gap:40px;">
                                <div style="text-align:center;">
                                    ${teamLogoHtml(m.homeTeamName, 60)}
                                    <div style="color:white;font-weight:700;font-size:1.1rem;">${m.homeTeamName}</div>
                                    <div style="color:rgba(255,255,255,0.4);font-size:0.75rem;">Ev Sahibi</div>
                                </div>
                                <div style="text-align:center;">${scoreHtml}</div>
                                <div style="text-align:center;">
                                    ${teamLogoHtml(m.awayTeamName, 60)}
                                    <div style="color:white;font-weight:700;font-size:1.1rem;">${m.awayTeamName}</div>
                                    <div style="color:rgba(255,255,255,0.4);font-size:0.75rem;">Deplasman</div>
                                </div>
                            </div>`;
                    });
            });

        // Maç olayları
        fetch(`http://localhost:7146/api/MatchEvent/GetByMatch?matchId=${matchId}`)
            .then(r => r.json())
            .then(events => {
                if(!events || events.length === 0) {
                    document.getElementById('events-container').innerHTML = '<p class="text-muted text-center">Henüz olay kaydedilmedi.</p>';
                    return;
                }
                let html = '';
                events.forEach(e => {
                    let icon = e.actionType==='Goal' ? '⚽' : e.actionType==='YellowCard' ? '🟨' : e.actionType==='RedCard' ? '🟥' : '🔄';
                    html += `<div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid #f0f0f0;">
                        <div style="font-size:1.2rem;">${icon}</div>
                        <div style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:#38003c;width:40px;">${e.minute}'</div>
                        <div>
                            <div style="font-weight:600;font-size:0.9rem;">${e.description}</div>
                            <div style="font-size:0.75rem;color:#6b7280;">${e.actionType}</div>
                        </div>
                    </div>`;
                });
                document.getElementById('events-container').innerHTML = html;
            });

        // İstatistikler
        fetch(`http://localhost:7146/api/MatchStatistics/GetByMatch?matchId=${matchId}`)
            .then(r => r.json())
            .then(s => {
                if(!s || !s.matchStatisticsId) {
                    document.getElementById('stats-container').innerHTML = '<p class="text-muted text-center">İstatistik henüz girilmedi.</p>';
                    return;
                }
                function statBar(label, home, away) {
                    const total = home + away || 1;
                    const homePct = Math.round((home/total)*100);
                    return `<div style="margin-bottom:16px;">
                        <div style="display:flex;justify-content:space-between;margin-bottom:4px;">
                            <span style="font-weight:700;color:#38003c;">${home}</span>
                            <span style="font-size:0.75rem;color:#6b7280;text-transform:uppercase;letter-spacing:0.5px;">${label}</span>
                            <span style="font-weight:700;color:#38003c;">${away}</span>
                        </div>
                        <div style="background:#f0f0f0;border-radius:4px;height:6px;overflow:hidden;">
                            <div style="background:#38003c;width:${homePct}%;height:100%;border-radius:4px;"></div>
                        </div>
                    </div>`;
                }
                document.getElementById('stats-container').innerHTML =
                    statBar('Top Hakimiyeti (%)', s.homePossession, s.awayPossession) +
                    statBar('Şut', s.homeShots, s.awayShots) +
                    statBar('Korner', s.homeCorners, s.awayCorners) +
                    statBar('İlk Yarı Golleri', s.homeFirstHalfGoals, s.awayFirstHalfGoals) +
                    statBar('İkinci Yarı Golleri', s.homeSecondHalfGoals, s.awaySecondHalfGoals);
            });
    </script>
}
