@model PremierLigi.WebUI.Dtos.MatchStatisticsDtos.CreateMatchStatisticsDto
@{
    Layout = null;
    int matchId = ViewBag.MatchId;
}
<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
<div class="container">
    <br />
    <h3>Maç İstatistiği Ekle</h3>
    <br />
    <form method="post" action="/MatchStatistics/CreateStatistics">
        <input type="hidden" name="MatchId" value="@matchId" />
        <div class="row">
            <div class="col-md-6">
                <h5>Ev Sahibi</h5>
                <div class="mb-3">
                    <label>İlk Yarı Golleri</label>
                    <input type="number" name="HomeFirstHalfGoals" class="form-control" value="0" min="0" />
                </div>
                <div class="mb-3">
                    <label>İkinci Yarı Golleri</label>
                    <input type="number" name="HomeSecondHalfGoals" class="form-control" value="0" min="0" />
                </div>
                <div class="mb-3">
                    <label>Top Hakimiyeti (%)</label>
                    <input type="number" name="HomePossession" class="form-control" value="50" min="0" max="100" />
                </div>
                <div class="mb-3">
                    <label>Şut</label>
                    <input type="number" name="HomeShots" class="form-control" value="0" min="0" />
                </div>
                <div class="mb-3">
                    <label>Korner</label>
                    <input type="number" name="HomeCorners" class="form-control" value="0" min="0" />
                </div>
            </div>
            <div class="col-md-6">
                <h5>Deplasman</h5>
                <div class="mb-3">
                    <label>İlk Yarı Golleri</label>
                    <input type="number" name="AwayFirstHalfGoals" class="form-control" value="0" min="0" />
                </div>
                <div class="mb-3">
                    <label>İkinci Yarı Golleri</label>
                    <input type="number" name="AwaySecondHalfGoals" class="form-control" value="0" min="0" />
                </div>
                <div class="mb-3">
                    <label>Top Hakimiyeti (%)</label>
                    <input type="number" name="AwayPossession" class="form-control" value="50" min="0" max="100" />
                </div>
                <div class="mb-3">
                    <label>Şut</label>
                    <input type="number" name="AwayShots" class="form-control" value="0" min="0" />
                </div>
                <div class="mb-3">
                    <label>Korner</label>
                    <input type="number" name="AwayCorners" class="form-control" value="0" min="0" />
                </div>
            </div>
        </div>
        <button type="submit" class="btn btn-primary">Kaydet</button>
        <a href="/Match/MatchList" class="btn btn-secondary">Geri Dön</a>
    </form>
</div>
